# entry point
port=59075
listen="0.0.0.0"
HOST_IP="202.199.13.164"  # 可选，指定 Worker 的对外 IP 地址，适用于多网卡或容器环境

# 端口池范围，worker 启动的容器会从这个范围里分配端口
port_pool_start=59081
port_pool_end=59100

# cgroup version (v1 or v2)
cgroup_version=2

# script path
dev_info_script_path=/home/pengyt/projects/neu_box/worker/scripts/info/gpu_info.sh
sandbox_script_path=/home/pengyt/projects/neu_box/worker/scripts/sanbox/v2/sandbox.sh

# device filter — regex matching device names under /dev (replaces device_major)
# nvidia[0-9]+ → matches nvidia0, nvidia1, ... (excludes nvidiactl, nvidia-uvm)
# davinci[0-9]+ → matches davinci0, davinci1, ...
device_filter=davinci[0-9]+

# DB directory (persist state across restarts)
db_dir=/home/pengyt/projects/neu_box/worker/db

# sandbox reaper — periodically destroy orphaned sandboxes whose ttyd has exited
sandbox_reaper_interval=30     # interval in seconds between reaper runs

# task scheduler — directory for task execution logs
task_log_dir=/home/pengyt/projects/neu_box/worker/logs
LOG_LEVEL=WARNING  # 可选，日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）

# maximum number of completed tasks to keep in the database
command_max_completed=200
# 队列视图中展示的最近完成任务数
QUEUE_RECENT_LIMIT=200

# time out
command_timeout=0 # 可选，任务执行超时时间（单位：秒），0 表示不限制超时